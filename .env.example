# MQTT Config
MQTT_BROKER=127.0.0.1
MQTT_USER=rlight
MQTT_PASS=securepass

# Oracle Cloud API
ORACLE_API_URL=https://api.oraclecloud.com/v1/portaria/receipts
ORACLE_BEARER=your_token_here

# SMTP Config (Weekly Reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=RLight Portaria <your_email@gmail.com>
SMTP_TO=admin@example.com

# Hardware
DEVICE_PATH=/dev/rlight_esp
