[Unit]
Description=RLight Portaria v8 Host Service
After=network.target

[Service]
Type=simple
User=willian
WorkingDirectory=/opt/rlight/host
Environment=PYTHONPATH=/opt/rlight/host
EnvironmentFile=/opt/rlight/host/.env
ExecStartPre=/bin/bash /opt/rlight/host/deploy.sh
ExecStart=/usr/bin/python3 /opt/rlight/host/main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
